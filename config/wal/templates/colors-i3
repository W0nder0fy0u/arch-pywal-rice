# pywal i3 colors — auto generated by pywal
# DO NOT edit this file directly
# Edit ~/.config/wal/templates/colors-i3 instead

set $bg       {background}
set $fg       {foreground}
set $accent   {color2}
set $urgent   {color1}
set $inactive {color8}

# Window borders           border    backgr.   text      indicator child_border
client.focused             $accent   $accent   $bg       $accent   $accent
client.focused_inactive    $inactive $inactive $fg       $inactive $inactive
client.unfocused           $bg       $bg       $fg       $bg       $bg
client.urgent              $urgent   $urgent   $bg       $urgent   $urgent

# i3bar — themed from wallpaper colors (60/30/10 rule)
bar {{
    status_command i3status
    position top

    colors {{
        background $bg
        statusline $fg
        separator  $accent

        # class              border    backgr    text
        focused_workspace    $accent   $accent   $bg
        active_workspace     $bg       $bg       $fg
        inactive_workspace   $bg       $bg       $inactive
        urgent_workspace     $urgent   $urgent   $bg
    }}
}}
