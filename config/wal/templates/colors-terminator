# pywal terminator theme — auto generated by pywal
# DO NOT edit this file directly
# Edit ~/.config/wal/templates/colors-terminator instead
#
# background_darkness: 0.2 = 80% transparent, 0.8 = 20% transparent

[global_config]
[keybindings]
[profiles]
  [[default]]
    background_color    = {background}
    foreground_color    = {foreground}
    cursor_color        = {color2}
    background_type     = transparent
    background_darkness = 0.2
    palette             = "{color0}:{color1}:{color2}:{color3}:{color4}:{color5}:{color6}:{color7}:{color8}:{color9}:{color10}:{color11}:{color12}:{color13}:{color14}:{color15}"
    use_system_font     = False
    font                = FiraCode Nerd Font 11
    show_titlebar       = False
    scrollbar_position  = hidden
[layouts]
  [[default]]
    [[[window0]]]
      type   = Window
      parent = ""
    [[[child1]]]
      type   = Terminal
      parent = window0
[plugins]
